#!/bin/bash
set -euo pipefail

menu() {
  local prompt="${1:-Power}"
  if command -v wofi >/dev/null 2>&1; then
    wofi --dmenu --prompt "$prompt"
  elif command -v rofi >/dev/null 2>&1; then
    rofi -dmenu -p "$prompt"
  elif command -v bemenu-run >/dev/null 2>&1; then
    bemenu -p "$prompt"
  else
    # no launcher installed; do nothing
    exit 0
  fi
}

confirm() {
  local msg="${1:-Are you sure?}"
  printf "No\nYes\n" | menu "$msg" | grep -qx "Yes"
}

choice=$(
  printf "Logout\nSuspend\nReboot\nShutdown\n" | menu "Power"
)

case "${choice:-}" in
  Logout)
    if confirm "Logout?"; then
      if command -v hyprctl >/dev/null 2>&1; then
        hyprctl dispatch exit
      else
        loginctl terminate-user "$USER"
      fi
    fi
    ;;
  Suspend)
    confirm "Suspend?" && systemctl suspend
    ;;
  Reboot)
    confirm "Reboot?" && systemctl reboot
    ;;
  Shutdown)
    confirm "Shutdown?" && systemctl poweroff
    ;;
  *)
    exit 0
    ;;
esac